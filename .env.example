# Discord Bot Token
# To get your bot token:
# 1. Go to https://discord.com/developers/applications
# 2. Create a new application
# 3. Go to the "Bot" section and click "Add Bot"
# 4. Copy the token and paste it below (remove the example token)
DISCORD_BOT_TOKEN=your_bot_token_here

# Proxy Configuration (Optional)
# If you need to use a proxy to connect to Discord, uncomment and configure below
# Format: http://username:password@host.docker.internal:port
# Example (HTTP proxy): http://user:pass@proxy.example.com:8080
# Example (SOCKS5 proxy): socks5://host.docker.internal:1080
# PROXY_URL=http://your_proxy_url:port

# Optional: proxy credentials as separate variables
# Useful when proxy URL should not include credentials
# PROXY_USERNAME=your_proxy_username
# PROXY_PASSWORD=your_proxy_password

# Fallback env vars also supported by the bot:
# HTTPS_PROXY=http://host.docker.internal:port
# HTTP_PROXY=http://host.docker.internal:port
# ALL_PROXY=http://host.docker.internal:port

# Bot instance metadata (recommended for multi-host diagnostics)
# Use a unique value per container/VM (e.g. hostname, pod name, or compose service name)
# BOT_INSTANCE_NAME=bot-prod-1

# Optional single-instance safety lock (Linux containers/hosts)
# When enabled, a second process on the same host exits immediately with a clear log message
# ENABLE_SINGLE_INSTANCE_LOCK=true
# BOT_LOCK_FILE_PATH=/tmp/discord_bot_single_instance.lock

# Web Admin Panel
# Enable embedded aiohttp-based admin panel
# ENABLE_WEB_ADMIN_PANEL=true
# WEB_ADMIN_HOST=0.0.0.0
# WEB_ADMIN_PORT=8080

# HTTP Basic auth credentials for the admin panel
# IMPORTANT: set strong credentials in production
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me
